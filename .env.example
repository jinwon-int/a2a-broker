PORT=8787
HOST=0.0.0.0
SERVICE_NAME=a2a-broker
# optional deployment/build identifier surfaced by /health and /dashboard
BROKER_RELEASE_REVISION=
# replace this placeholder before startup; broker boot now fails fast if left masked
PUBLIC_BASE_URL=http://<masked-host>:8787
STATE_FILE=/var/lib/a2a-broker/state.json
BROKER_PERSISTENCE_BACKEND=json-file
BROKER_SQLITE_FILE=/var/lib/a2a-broker/state.sqlite
# snapshot (default) or hot-tables
BROKER_SQLITE_LOAD_SOURCE=snapshot
WORKER_OFFLINE_AFTER_SEC=90
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=10
WORKER_RATE_LIMIT_WINDOW_SEC=60
WORKER_RATE_LIMIT_MAX_REQUESTS=60
ENFORCE_REQUESTER_IDENTITY=1
TRUSTED_PROXY=0
EDGE_SECRET=
BROKER_EDGE_SECRET=

# worker daemon example settings
BROKER_URL=http://127.0.0.1:8787
WORKER_ID=worker-a
WORKER_ROLE=analyst
WORKER_REQUESTER_KIND=node
WORKER_HANDLER_BUILTIN=echo
WORKER_POLL_INTERVAL_MS=5000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_HANDLER_TIMEOUT_MS=60000
WORKER_CAN_ANALYZE=1
WORKER_CAN_BACKFILL=0
WORKER_CAN_PATCH_WORKSPACE=0
WORKER_CAN_PROMOTE_LIVE=0
WORKER_WORKSPACE_IDS=test
WORKER_ENVIRONMENTS=research
