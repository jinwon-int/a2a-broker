# Broker HTTP identity
PORT=8787
HOST=0.0.0.0
SERVICE_NAME=a2a-broker
# Replace this placeholder before startup; broker boot fails fast if left masked.
PUBLIC_BASE_URL=http://<masked-host>:8787

# Broker durable identity and team ownership
A2A_BROKER_ID=
# Legacy alias for A2A_BROKER_ID
BROKER_ID=
A2A_TEAM_ID=

# Broker build metadata surfaced by /health and /dashboard
A2A_BROKER_VERSION=
A2A_BROKER_REVISION=
# Legacy revision aliases, checked after A2A_BROKER_REVISION
BROKER_RELEASE_REVISION=
RELEASE_REVISION=
A2A_BROKER_SOURCE=
A2A_BROKER_BUILT_AT=
A2A_BROKER_RUNTIME=
# Optional OCI image metadata (safe compact values only)
A2A_BROKER_IMAGE_TAG=
A2A_BROKER_IMAGE_DIGEST=

# Broker persistence
STATE_FILE=/var/lib/a2a-broker/state.json
STATE_FILE_MAX_BYTES=
BROKER_PERSISTENCE_BACKEND=json-file
BROKER_SQLITE_FILE=/var/lib/a2a-broker/state.sqlite
# Compatibility alias for BROKER_SQLITE_FILE; takes precedence when set.
SQLITE_STATE_FILE=
# snapshot (default) or hot-tables
BROKER_SQLITE_LOAD_SOURCE=snapshot
# Bounded hot-table runtime hydration caps when BROKER_SQLITE_LOAD_SOURCE=hot-tables.
# Active tasks are always hydrated; this cap applies to terminal tasks only.
BROKER_HOT_RUNTIME_MAX_TERMINAL_TASKS=2000
BROKER_HOT_RUNTIME_MAX_AUDIT_EVENTS=5000
BROKER_HOT_RUNTIME_MAX_TERMINAL_OUTBOX_EVENTS=1000

# Broker request security, rate limits, and stale-task recovery
WORKER_OFFLINE_AFTER_SEC=90
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=10
WORKER_RATE_LIMIT_WINDOW_SEC=60
WORKER_RATE_LIMIT_MAX_REQUESTS=60
ENFORCE_REQUESTER_IDENTITY=1
TRUSTED_PROXY=0
EDGE_SECRET=
# Compatibility alias for broker edge auth
A2A_EDGE_SECRET=
STALE_REAPER_ENABLED=1
STALE_REAPER_INTERVAL_SEC=60
STALE_REAPER_OLDER_THAN_SEC=90
BROKER_MAX_REQUEUE_ATTEMPTS=5
TASK_SUBSCRIBE_HEARTBEAT_SEC=15
A2A_PEER_STATUS_ENABLED=0

# Broker retention policy overrides
BROKER_TERMINAL_RETENTION_MS=
BROKER_MAX_TERMINAL_EXCHANGES=
BROKER_MAX_TERMINAL_TASKS=
BROKER_MAX_TERMINAL_PROPOSALS=
BROKER_INACTIVE_WORKER_RETENTION_MS=
BROKER_MAX_INACTIVE_WORKERS=
BROKER_AUDIT_RETENTION_MS=
BROKER_MAX_AUDIT_EVENTS=

# Worker daemon broker connection
BROKER_URL=http://127.0.0.1:8787
# Compatibility alias for BROKER_URL
A2A_BROKER_URL=
# Worker client edge-secret lookup order: BROKER_EDGE_SECRET, A2A_BROKER_EDGE_SECRET, EDGE_SECRET, A2A_EDGE_SECRET.
BROKER_EDGE_SECRET=
A2A_BROKER_EDGE_SECRET=

# Worker home-broker pinning; fail closed unless /health brokerId matches.
A2A_HOME_BROKER_ID=
HOME_BROKER_ID=
A2A_HOME_BROKER_LEASE_FILE=
HOME_BROKER_LEASE_FILE=

# Worker identity and advertised metadata
WORKER_ID=worker-a
A2A_WORKER_ID=
NODE_ID=
WORKER_ROLE=analyst
A2A_WORKER_ROLE=
WORKER_REQUESTER_KIND=node
A2A_WORKER_REQUESTER_KIND=
WORKER_DISPLAY_NAME=
A2A_WORKER_DISPLAY_NAME=
WORKER_PUBLIC_URL=
A2A_WORKER_PUBLIC_URL=
WORKER_METADATA_JSON=
A2A_WORKER_METADATA_JSON=
WORKER_USER_AGENT=
A2A_WORKER_USER_AGENT=

# Worker handler configuration
WORKER_HANDLER_BUILTIN=echo
A2A_WORKER_HANDLER_BUILTIN=
WORKER_HANDLER_COMMAND=
A2A_WORKER_HANDLER_COMMAND=
WORKER_HANDLER_ARGS_JSON=
A2A_WORKER_HANDLER_ARGS_JSON=
WORKER_HANDLER_CWD=
A2A_WORKER_HANDLER_CWD=
WORKER_HANDLER_TIMEOUT_MS=60000
A2A_WORKER_HANDLER_TIMEOUT_MS=
WORKER_POLL_INTERVAL_MS=5000
A2A_WORKER_POLL_INTERVAL_MS=
WORKER_HEARTBEAT_INTERVAL_MS=30000
A2A_WORKER_HEARTBEAT_INTERVAL_MS=

# Worker capabilities; WORKER_CAPABILITIES_JSON overrides individual capability flags when set.
WORKER_CAPABILITIES_JSON=
A2A_WORKER_CAPABILITIES_JSON=
WORKER_CAN_ANALYZE=1
A2A_WORKER_CAN_ANALYZE=
WORKER_CAN_BACKFILL=0
A2A_WORKER_CAN_BACKFILL=
WORKER_CAN_PATCH_WORKSPACE=0
A2A_WORKER_CAN_PATCH_WORKSPACE=
WORKER_CAN_PROMOTE_LIVE=0
A2A_WORKER_CAN_PROMOTE_LIVE=
WORKER_WORKSPACE_IDS=test
A2A_WORKER_WORKSPACE_IDS=
WORKER_ENVIRONMENTS=research
A2A_WORKER_ENVIRONMENTS=
