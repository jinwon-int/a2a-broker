# Gwakga→Seoseo handoff receiver env example.
# Copy to a local, ignored env file before use. Do not commit real secrets,
# private host paths, raw session logs, or generated receiver state.

# Default-off guard: keep disabled until an operator approves the receiver window.
GWAKGA_SEOSEO_RECEIVER_ENABLED=0
GWAKGA_SEOSEO_RECEIVER_MODE=dry-run

# Ownership and routing invariants.
GWAKGA_SEOSEO_BROKER_OF_RECORD=seoseo
GWAKGA_SEOSEO_REQUESTED_BY_BROKER=gwakga
GWAKGA_SEOSEO_TARGET_TEAM=team1
GWAKGA_SEOSEO_ALLOWED_STATUS_VALUES=accepted,running,pr-open,done,blocked

# Parent GitHub issue or repository watched for structured handoff manifests
# or /a2a assign comments. Keep tokens in the runtime secret store, not here.
GWAKGA_SEOSEO_PARENT_REPO=jinwon-int/a2a-plane
GWAKGA_SEOSEO_PARENT_ISSUE=
GWAKGA_SEOSEO_GITHUB_TOKEN=

# Broker URLs use public aliases/placeholders. Replace only in local env.
SEOSEO_BROKER_URL=https://seoseo-broker.example.invalid
GWAKGA_BROKER_URL=https://gwakga-broker.example.invalid

# Secret values are intentionally blank. Supply from the Seoseo/Gwakga runtime
# secret stores or local shell. Never print these in GitHub/chat/artifacts.
SEOSEO_BROKER_EDGE_SECRET=
GWAKGA_BROKER_EDGE_SECRET=

# Durable receiver state. Use a receiver-owned path in the deployed runtime;
# do not point this at a shared worker workspace.
GWAKGA_SEOSEO_RECEIVER_STATE_FILE=/var/lib/a2a-broker/gwakga-seoseo-receiver/state.sqlite

# Safety defaults for generated Seoseo tasks.
GWAKGA_SEOSEO_REQUIRE_IDEMPOTENCY_KEY=1
GWAKGA_SEOSEO_REJECT_UNKNOWN_WORKER=1
GWAKGA_SEOSEO_REJECT_WRONG_TARGET_TEAM=1
GWAKGA_SEOSEO_REDACT_SECRETS=1
GWAKGA_SEOSEO_CREATE_TASKS=0

# Read-only package checks.
# npm run gwakga_seoseo_receiver_preflight -- --seoseo-url "$SEOSEO_BROKER_URL" --gwakga-url "$GWAKGA_BROKER_URL" --json
# npm run gwakga_seoseo_receiver_receipt_parity -- --seoseo-url "$SEOSEO_BROKER_URL" --gwakga-url "$GWAKGA_BROKER_URL" --seoseo-edge-secret "$SEOSEO_BROKER_EDGE_SECRET" --gwakga-edge-secret "$GWAKGA_BROKER_EDGE_SECRET" --limit 20 --json
