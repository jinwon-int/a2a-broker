# Team2/Gwakga worker env example.
# Copy to a local, ignored env file before use. Do not commit real secrets or host paths.

# Identity: one worker ID has one active home broker.
WORKER_ID=soonwook
WORKER_DISPLAY_NAME=soonwook-team2-gwakga-worker
WORKER_ROLE=analyst
WORKER_REQUESTER_KIND=node

# Target broker: replace with the approved Gwakga broker URL.
BROKER_URL=https://gwakga-broker.example.invalid

# Secret value is intentionally blank. Supply from the runtime secret store or local shell.
BROKER_EDGE_SECRET=

# Structured ownership metadata reported on register/heartbeat.
# For a new Gwakga-only worker, omit previousHomeBrokerId.
WORKER_METADATA_JSON={"brokerId":"gwakga","teamId":"team2","homeBrokerId":"gwakga","previousHomeBrokerId":"seoseo","retargetRun":"a2a-2broker-safety-20260507T021114Z"}

# Polling/heartbeat defaults are conservative and match the broker worker daemon defaults.
WORKER_POLL_INTERVAL_MS=5000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_HANDLER_TIMEOUT_MS=60000

# Capabilities: start narrow; expand only with explicit operator approval.
WORKER_CAN_ANALYZE=1
WORKER_CAN_BACKFILL=0
WORKER_CAN_PATCH_WORKSPACE=0
WORKER_CAN_PROMOTE_LIVE=0
WORKER_WORKSPACE_IDS=team2-gwakga
WORKER_ENVIRONMENTS=research

# Handler wiring: prefer a reviewed handler artifact/path for real onboarding.
WORKER_HANDLER_BUILTIN=echo
# WORKER_HANDLER_COMMAND=node
# WORKER_HANDLER_ARGS_JSON=["/app/scripts/openclaw-a2a-task-handler.mjs"]
