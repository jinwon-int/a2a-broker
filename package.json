{
  "name": "a2a-broker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal standalone A2A broker scaffold",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/*.test.js dist/core/*.test.js dist/a2a/*.test.js dist/github/*.test.js dist/workers/*.test.js",
    "reconcile_closeout": "node scripts/closeout-reconcile.mjs",
    "command_center_closeout_checklist": "node scripts/command-center-closeout-checklist.mjs",
    "test:worker": "npm run build && node --test dist/worker.test.js",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "smoke:restart-recovery": "node scripts/restart-recovery-smoke.mjs",
    "smoke:docker-broker": "node scripts/docker-broker-live-smoke.mjs",
    "smoke:docker-broker:fleet": "node scripts/docker-broker-live-smoke.mjs --fleet --require-workers bangtong,dungae,sogyo,nosuk",
    "export:sqlite": "node scripts/export-sqlite-state.mjs",
    "dev": "node --watch --enable-source-maps src/server.ts",
    "dev:worker": "node --watch --enable-source-maps src/worker.ts",
    "release_gate": "node scripts/release-gate.mjs",
    "docker_runtime_preflight": "node scripts/docker-runtime-preflight.mjs",
    "rollout_guard": "node scripts/worker-artifact-rollout-guard.mjs",
    "terminal_outbox_preflight": "node scripts/terminal-outbox-preflight.mjs",
    "live_readiness_canary": "node scripts/broker-live-readiness-canary.mjs",
    "receipt_gate_canary": "node scripts/receipt-gate-canary.mjs",
    "terminal_receipt_gap_matrix": "node scripts/terminal-receipt-gap-matrix.mjs",
    "terminal_outbox_backlog_classifier": "node scripts/terminal-receipt-closeout-report.mjs",
    "terminal_outbox_cleanup_dryrun": "node scripts/terminal-receipt-closeout-report.mjs",
    "lifecycle_proof_evidence": "node scripts/broker-lifecycle-proof-evidence.mjs",
    "migration_health_gate": "node scripts/broker-migration-health-gate.mjs",
    "terminal_receipt_closeout_report": "node scripts/terminal-receipt-closeout-report.mjs",
    "terminal_brief_completion_watcher": "npm run build && node scripts/terminal-brief-completion-watcher.mjs",
    "terminal_brief_final_count_closeout": "npm run build && node scripts/terminal-brief-final-count-closeout.mjs",
    "terminal_brief_sidecar_integration_rehearsal": "npm run build && node scripts/terminal-brief-sidecar-integration-rehearsal.mjs",
    "terminal_brief_finalizer_handoff": "npm run build && node scripts/terminal-brief-finalizer-handoff.mjs",
    "terminal_brief_finalizer_workflow": "npm run build && node scripts/terminal-brief-finalizer-workflow.mjs",
    "terminal_brief_closeout_gate": "npm run build && node scripts/terminal-brief-closeout-gate.mjs",
    "terminal_brief_approval_request": "npm run build && node scripts/terminal-brief-approval-request.mjs",
    "terminal_brief_approval_executor": "npm run build && node scripts/terminal-brief-approval-executor.mjs",
    "terminal_brief_approval_dispatch": "npm run build && node scripts/terminal-brief-approval-dispatch.mjs",
    "terminal_brief_approval_receipt_ingestor": "npm run build && node scripts/terminal-brief-approval-receipt-ingestor.mjs",
    "terminal_brief_finalizer_approval_status": "npm run build && node scripts/terminal-brief-finalizer-approval-status.mjs",
    "terminal_brief_sidecar_dry_run_gate": "npm run build && node scripts/terminal-brief-sidecar-dry-run-gate.mjs",
    "terminal_brief_sidecar_activation_approval": "npm run build && node scripts/terminal-brief-sidecar-activation-approval.mjs",
    "terminal_brief_sidecar_activation_receipt_ingestor": "npm run build && node scripts/terminal-brief-sidecar-activation-receipt-ingestor.mjs",
    "terminal_brief_sidecar_start_executor_gate": "npm run build && node scripts/terminal-brief-sidecar-start-executor-gate.mjs",
    "terminal_brief_sidecar_executor_invocation_rehearsal": "npm run build && node scripts/terminal-brief-sidecar-executor-invocation-rehearsal.mjs",
    "terminal_brief_sidecar_runtime_preflight_approval": "npm run build && node scripts/terminal-brief-sidecar-runtime-preflight-approval.mjs",
    "terminal_brief_sidecar_dry_run_start_canary_plan": "npm run build && node scripts/terminal-brief-sidecar-dry-run-start-canary-plan.mjs",
    "terminal_brief_sidecar_preflight_evidence_collector": "npm run build && node scripts/terminal-brief-sidecar-preflight-evidence-collector.mjs",
    "terminal_brief_sidecar_preflight_chain_review": "npm run build && node scripts/terminal-brief-sidecar-preflight-chain-review.mjs",
    "terminal_brief_sidecar_dry_run_start_approval_request": "npm run build && node scripts/terminal-brief-sidecar-dry-run-start-approval-request.mjs",
    "terminal_brief_sidecar_dry_run_start_approval_receipt_ingestor": "npm run build && node scripts/terminal-brief-sidecar-dry-run-start-approval-receipt-ingestor.mjs",
    "broker_cleanup_safe_prune": "npm run build && node scripts/broker-cleanup-safe-prune.mjs",
    "terminal_brief_activation_report": "node scripts/terminal-brief-activation-report.mjs",
    "test:terminal_brief_activation_report": "node --test scripts/terminal-brief-activation-report.test.mjs",
    "closeout_release_report": "node scripts/closeout-release-report.mjs",
    "rehearsal_manifest": "node scripts/broker-rehearsal-manifest.mjs",
    "source_public_approval_rehearsal": "npm run build && node scripts/source-public-approval-rehearsal.mjs",
    "source_public_execution_orchestrator": "npm run build && node scripts/source-public-execution-orchestrator.mjs",
    "scan:public-readiness": "node scripts/public-readiness-scan.mjs",
    "two_broker_worker_preflight": "node scripts/two-broker-worker-preflight.mjs",
    "gwakga_seoseo_receiver_preflight": "node scripts/two-broker-worker-preflight.mjs",
    "gwakga_seoseo_receiver_receipt_parity": "npm run build && node scripts/broker-terminal-receipt-parity.mjs",
    "broker_terminal_receipt_parity": "npm run build && node scripts/broker-terminal-receipt-parity.mjs",
    "edge_secret_rotation_diagnostics": "node scripts/edge-secret-rotation-diagnostics.mjs",
    "test:edge_secret_rotation_diagnostics": "node --test scripts/edge-secret-rotation-diagnostics.test.mjs",
    "release_evidence_export": "npm run build && node dist/release-evidence-export.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
